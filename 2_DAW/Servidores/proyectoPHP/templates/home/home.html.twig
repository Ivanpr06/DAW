{% extends 'base.html.twig' %}

{% block title %}HOME | CARTOON LOST{% endblock %}

{% block body %}
<style>
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background-color: var(--bg-color);
        color: var(--text-main);
        font-family: var(--font-body);
        overflow-x: hidden;
    }

    .scanlines {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(
            to bottom,
            rgba(255,255,255,0),
            rgba(255,255,255,0) 50%,
            rgba(0,0,0,0.2) 50%,
            rgba(0,0,0,0.2)
        );
        background-size: 100% 4px;
        pointer-events: none;
        z-index: 999;
    }

    .hero {
        height: 60vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 0 40px;
        border-bottom: 1px solid #333;
        background: radial-gradient(circle at 80% 50%, #1a1a1a 0%, var(--bg-color) 70%);
    }

    .hero h1 {
        font-family: var(--font-head);
        font-size: 5rem;
        line-height: 0.9;
        margin-bottom: 20px;
        text-transform: uppercase;
    }

    .hero h1 span {
        color: var(--accent);
        display: block;
        font-size: 1.5rem;
        font-family: var(--font-body);
        letter-spacing: 5px;
        margin-bottom: 10px;
    }

    .hero p {
        max-width: 600px;
        line-height: 1.6;
        color: #aaa;
        margin-bottom: 30px;
    }

    .btn {
        display: inline-block;
        padding: 12px 30px;
        background: transparent;
        border: 1px solid var(--accent);
        color: var(--accent);
        font-family: var(--font-body);
        font-weight: bold;
        text-transform: uppercase;
        cursor: pointer;
        text-decoration: none;
        width: fit-content;
        transition: all 0.3s;
    }

    .btn:hover {
        background: var(--accent);
        color: black;
        box-shadow: 0 0 15px var(--accent-dim);
    }

    .container {
        padding: 60px 40px;
    }

    .section-title {
        font-family: var(--font-head);
        font-size: 2rem;
        margin-bottom: 40px;
        display: flex;
        align-items: center;
        gap: 15px;
        margin-left: 20px;
    }

    .section-title::before {
        content: '';
        display: block;
        width: 10px;
        height: 40px;
        background-color: var(--accent);
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 30px;
    }

    .card {
        background-color: var(--card-bg);
        border: 1px solid #333;
        transition: all 0.3s ease;
        position: relative;
    }

    .card:hover {
        border-color: var(--accent);
        transform: translateY(-5px);
    }

    .card-image {
        width: 100%;
        height: 200px;
        object-fit: cover;
        filter: grayscale(100%) contrast(1.2);
        transition: filter 0.4s;
        border-bottom: 1px solid #333;
    }

    .card:hover .card-image {
        filter: grayscale(0%) contrast(1);
    }

    .card-content {
        padding: 20px;
    }

    .card-meta {
        font-size: 0.75rem;
        color: #666;
        margin-bottom: 10px;
        display: flex;
        justify-content: space-between;
    }

    .card h3 {
        font-size: 1.2rem;
        margin-bottom: 15px;
        font-weight: 700;
    }

    .rating-box {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 15px;
        font-size: 0.9rem;
    }

    .score {
        background-color: var(--accent);
        color: black;
        padding: 2px 8px;
        font-weight: bold;
    }

    footer {
        padding: 40px;
        border-top: 1px solid #333;
        text-align: center;
        font-size: 0.8rem;
        color: #555;
        margin-top: 50px;
    }

    @media (max-width: 768px) {
        .hero h1 { font-size: 3rem; }
        header { padding: 20px; }
        .container { padding: 40px 20px; }
    }

    .blade-grid.horizontal-mode {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        padding: 20px;
    }

    .blade-grid.horizontal-mode {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        padding: 20px;
    }

    .cyber-blade {
        position: relative;
        width: 450px;
        height: 150px;
        display: flex;
        background: #050505;
        border: 1px solid #333;
        cursor: pointer;
        transition: all 0.3s ease;
        overflow: hidden;
        clip-path: polygon(
            10px 0, 100% 0,
            100% calc(100% - 10px),
            calc(100% - 10px) 100%,
            0 100%, 0 10px
        );
        margin-bottom: 15px;
        text-decoration: none;
        color: inherit;
    }

    .blade-img-container {
        width: 50%;
        height: 100%;
        position: relative;
        border-right: 2px solid var(--neon-cyan);
        border-bottom: none;
    }

    .blade-img-container img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: grayscale(100%) contrast(1.2) brightness(0.8);
        transition: 0.4s;
    }

    .blade-content {
        width: 65%;
        height: 100%;
        padding: 15px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background: linear-gradient(90deg, rgba(0,243,255,0.05) 0%, rgba(0,0,0,0) 100%);
    }

    .blade-name {
        font-family: 'Archivo Black', sans-serif;
        color: #fff;
        font-size: 1rem;
        line-height: 1.2;
        text-transform: uppercase;
        margin-bottom: 8px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .blade-id {
        font-family: 'Courier New', monospace;
        font-size: 0.75rem;
        color: var(--neon-cyan);
        opacity: 0.8;
        letter-spacing: 1px;
    }

    .status-light {
        position: absolute;
        top: 10px;
        right: 10px;
        width: 6px;
        height: 6px;
        background: #333;
        border-radius: 50%;
    }

    .cyber-blade:hover {
        background: #050505 !important;
        border: 1px solid #00f3ff !important;
        box-shadow: inset 0 0 10px rgba(0, 243, 255, 0.3);
        filter: drop-shadow(0 0 5px #00f3ff);
        transform: translateX(5px);
        color: #fff !important;
        text-decoration: none !important;
    }

    .cyber-blade:hover img {
        filter: grayscale(0%) contrast(1.1) brightness(1);
    }

    .cyber-blade:hover .status-light,
    .cyber-blade.selected .status-light {
        background: var(--neon-cyan);
        box-shadow: 0 0 8px var(--neon-cyan);
    }

    .cyber-blade.selected {
        border: 2px solid var(--neon-cyan);
        background: rgba(0, 243, 255, 0.05);
    }
    .cyber-blade.selected img {
        filter: grayscale(0%);
    }
</style>

    <div class="scanlines"></div>

    <section class="hero">
        <h1><span>System Loaded</span>Nostalgia<br>Rebooted</h1>
        <p>Base de datos clasificada de animación 1990-2010. Análisis técnico, narrativa madura y preservación histórica. Bienvenido al archivo.</p>
        <a href="{{ path('app_serie') }}" class="btn">Explorar Series</a>
    </section>

    <div class="section-title" style="margin-top: 75px">Ver Nota de Rankings</div>

    <div class="blade-grid horizontal-mode">
        {% for categoria in categorias %}
            <a href="{{ path('app_rankingNota', {'id': categoria.id}) }}" class="cyber-blade">

                <div class="blade-img-container">
                    <img src="{{ categoria.imagen }}" alt="{{ categoria.nombre }}">
                </div>

                <div class="blade-content">
                    <div class="blade-name">{{ categoria.nombre }}</div>
                </div>

                <div class="status-light"></div>
            </a>
        {% endfor %}
    </div>

    <footer>
        <p>CARTOON LOST © 2024. All signals reserved.<br>Designed for the lost generation.</p>
    </footer>
{% endblock %}
