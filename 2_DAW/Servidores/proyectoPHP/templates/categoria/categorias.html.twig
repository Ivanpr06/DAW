{% extends 'base.html.twig' %}

{% block title %}
    {% if categoria_editar is defined and categoria_editar %}
        EDIT_CATEGORY | CARTOON LOST
    {% else %}
        NEW_CATEGORY | CARTOON LOST
    {% endif %}
{% endblock %}

{% block navbar %}{% endblock %}

{% block body %}
    <style>
        :root {
            /* CAMBIO: Color fijo siempre Cian, sin condicionales */
            --accent: #00ffff;
            --bg-panel: #0a0a0a;
            --border-color: #333;
        }

        .admin-container {
            display: grid;
            grid-template-columns: 260px 1fr;
            min-height: 100vh;
            font-family: 'Roboto Mono', monospace;
            background-color: #020202;
            color: #ccc;
        }

        .admin-content { padding: 40px; overflow-y: auto; }

        .panel-header {
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 15px;
            margin-bottom: 40px;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }

        .panel-header h1 {
            font-family: 'Archivo Black', sans-serif;
            font-size: 1.8rem;
            margin: 0;
            color: white;
            text-transform: uppercase;
            letter-spacing: -1px;
        }

        .panel-header .subtitle { color: var(--accent); font-size: 0.8rem; letter-spacing: 2px; }

        .cyber-form {
            max-width: 1000px;
            background: var(--bg-panel);
            border: 1px solid var(--border-color);
            padding: 30px;
            position: relative;
            scroll-margin-top: 20px;
        }

        .cyber-form::before {
            content: ''; position: absolute; top: -1px; left: -1px;
            width: 20px; height: 20px;
            border-top: 2px solid var(--accent); border-left: 2px solid var(--accent);
        }
        .cyber-form::after {
            content: ''; position: absolute; bottom: -1px; right: -1px;
            width: 20px; height: 20px;
            border-bottom: 2px solid var(--accent); border-right: 2px solid var(--accent);
        }

        .form-grid-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 25px;
        }

        .form-group { margin-bottom: 25px; }
        .form-group.full-width { grid-column: 1 / -1; }

        .form-group label {
            display: block;
            margin-bottom: 10px;
            color: #666;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .cyber-input {
            width: 100%;
            background: #000;
            border: 1px solid #333;
            border-left: 3px solid #333;
            color: var(--accent);
            padding: 12px 15px;
            font-family: 'Roboto Mono', monospace;
            font-size: 0.9rem;
            outline: none;
            transition: all 0.3s ease;
            box-sizing: border-box;
        }

        /* CAMBIO: Eliminado el bloque extra que ponía sombra naranja */
        .cyber-input:focus {
            border-color: var(--accent);
            border-left-color: var(--accent);
            box-shadow: 0 0 15px rgba(0, 255, 255, 0.1);
        }

        .cyber-input::placeholder { color: #333; }

        textarea.cyber-input { resize: vertical; min-height: 100px; }

        .selection-section-title {
            margin-top: 40px;
            margin-bottom: 20px;
            color: white;
            font-family: 'Archivo Black', sans-serif;
            font-size: 1.2rem;
            border-bottom: 1px dashed #333;
            padding-bottom: 10px;
        }

        .series-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 15px;
            max-height: 500px;
            overflow-y: auto;
            padding-right: 10px;
        }

        .series-grid::-webkit-scrollbar { width: 6px; }
        .series-grid::-webkit-scrollbar-track { background: #111; }
        .series-grid::-webkit-scrollbar-thumb { background: #333; }

        .serie-card {
            position: relative;
            cursor: pointer;
            border: 3px solid #333;
            transition: all 0.2s;
            background: #000;
        }

        .serie-card:hover { border-color: #666; transform: translateY(-2px); }

        /* CAMBIO: Estilo seleccionado usa el color cyan base */
        .serie-card.selected {
            border-color: var(--accent);
            box-shadow: 0 0 10px rgba(0, 255, 255, 0.2);
        }
        .serie-card.selected img { opacity: 1; filter: grayscale(0%); }

        .serie-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            display: block;
            opacity: 0.7;
            transition: opacity 0.3s;
            filter: grayscale(100%);
        }

        .serie-card:hover img { opacity: 1; filter: grayscale(0%); }

        .serie-name-mini {
            padding: 5px;
            font-size: 0.65rem;
            color: #888;
            text-align: center;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .btn-submit {
            display: inline-block;
            width: 100%;
            margin-top: 30px;
            padding: 15px;
            background-color: var(--accent);
            color: #000;
            border: none;
            font-family: 'Archivo Black', sans-serif;
            font-size: 1.1rem;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.3s;
            clip-path: polygon(0 0, 100% 0, 100% 85%, 98% 100%, 0 100%);
        }

        .btn-submit:hover {
            background-color: #fff;
            box-shadow: 0 0 20px var(--accent);
        }

        .btn-cancel {
            display: block;
            text-align: center;
            margin-top: 15px;
            color: #666;
            text-decoration: none;
            font-size: 0.8rem;
            text-transform: uppercase;
        }
        .btn-cancel:hover { color: #fff; }

        .categories-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 50px;
        }

        .cyber-card {
            background: #0a0a0a;
            border: 1px solid #333;
            display: flex;
            flex-direction: column;
            position: relative;
            transition: transform 0.2s, border-color 0.2s;
        }

        /* CAMBIO: Active editing ya no usa naranja, usa var(--accent) que es cian */
        .cyber-card.active-editing {
            border-color: var(--accent);
            box-shadow: 0 0 15px rgba(0, 255, 255, 0.2);
        }

        .cyber-card:hover {
            border-color: #555;
            transform: translateY(-5px);
            box-shadow: 0 5px 20px rgba(0,0,0,0.5);
        }

        .cyber-card::before {
            content: ''; position: absolute; top: 0; right: 0;
            border-width: 0 20px 20px 0;
            border-style: solid;
            border-color: #222 transparent transparent #222;
            display: block; width: 0;
        }

        .card-img-wrapper {
            height: 140px;
            overflow: hidden;
            border-bottom: 1px solid #333;
            position: relative;
        }

        .card-img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center;
            filter: grayscale(80%);
            transition: filter 0.3s;
        }

        .cyber-card:hover .card-img-wrapper img { filter: grayscale(0%); }

        .card-body {
            padding: 20px;
            flex-grow: 1;
        }

        .card-title {
            color: #00ffff;
            font-size: 1.1rem;
            margin: 0 0 10px 0;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .card-desc {
            color: #777;
            font-size: 0.85rem;
            line-height: 1.4;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .card-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            border-top: 1px solid #333;
        }

        .action-btn {
            text-align: center;
            padding: 12px 0;
            text-decoration: none;
            font-size: 0.8rem;
            font-weight: bold;
            text-transform: uppercase;
            transition: all 0.2s;
            cursor: pointer;
        }

        .btn-edit {
            background: #111;
            color: #aaa;
            border-right: 1px solid #333;
        }
        .btn-edit:hover { background: #1a1a1a; color: white; }

        .btn-delete {
            background: #150505;
            color: #ff4444;
        }
        .btn-delete:hover {
            background: #ff4444;
            color: black;
        }
    </style>

    <div class="admin-container">

        {% include 'admin/adminNavbar.html.twig' %}

        <main class="admin-content">

            <div class="panel-header">
                <div>
                    <h1>
                        {% if categoria_editar is defined and categoria_editar %}
                            MODIFY_ENTRY
                        {% else %}
                            CREATE_ENTRY
                        {% endif %}
                    </h1>
                    <div class="subtitle">> DATABASE //
                        {% if categoria_editar is defined and categoria_editar %}
                            UPDATE_CATEGORY_ID_{{ categoria_editar.id }}
                        {% else %}
                            NEW_CATEGORY
                        {% endif %}
                    </div>
                </div>
                <div class="subtitle">SYS_TIME: {{ "now"|date("H:i") }}</div>
            </div>

            <h2>Categories</h2>
            <div class="categories-grid">
                {% for categoria in categorias %}
                    <div class="cyber-card {% if categoria_editar is defined and categoria_editar and categoria_editar.id == categoria.id %}active-editing{% endif %}">

                        <div class="card-img-wrapper">
                            <img src="{{ categoria.imagen }}" alt="{{ categoria.nombre }}">
                        </div>

                        <div class="card-body">
                            <h3 class="card-title">{{ categoria.nombre }}</h3>
                            <p class="card-desc">{{ categoria.descripcion }}</p>
                        </div>

                        <div class="card-actions">
                            <a href="{{ path('app_categoriaEditar', {'id': categoria.id}) }}" class="action-btn btn-edit">
                                [ EDIT ]
                            </a>

                            <a href="{{ path('app_categoriaEliminar', {'id': categoria.id}) }}" class="action-btn btn-delete">
                                [ DELETE ]
                            </a>
                        </div>
                    </div>
                {% else %}
                    <p style="color:#666;">No data found</p>
                {% endfor %}
            </div>

            <form id="mainForm" method="POST"
                  action="{% if categoria_editar is defined and categoria_editar %}{{ path('app_categoriaEditar', {'id': categoria_editar.id}) }}{% else %}{{ path('app_categoria') }}{% endif %}"
                  class="cyber-form">

                <div class="form-grid-row">
                    <div class="form-group">
                        <label>CATEGORY_NAME_ID</label>
                        <input type="text" name="nombre" class="cyber-input" placeholder="Ex: CYBERPUNK_GENRE" required autocomplete="off"
                               value="{{ categoria_editar is defined and categoria_editar ? categoria_editar.nombre : '' }}">
                    </div>

                    <div class="form-group">
                        <label>COVER_IMAGE_SOURCE</label>
                        <input type="text" name="imagen" class="cyber-input" placeholder="https://..." required autocomplete="off"
                               value="{{ categoria_editar is defined and categoria_editar ? categoria_editar.imagen : '' }}">
                    </div>
                </div>

                <div class="form-group">
                    <label>DATA_DESCRIPTION</label>
                    <textarea name="descripcion" class="cyber-input" rows="3" placeholder="Input category description..." required>{{ categoria_editar is defined and categoria_editar ? categoria_editar.descripcion : '' }}</textarea>
                </div>

                <div class="selection-section-title">
                    {% if categoria_editar is defined and categoria_editar %}>> UPDATE_LINKED_SERIES{% else %}>> LINK_SERIES_TO_CATEGORY{% endif %}
                </div>

                {% set ids_iniciales = '' %}
                {% if categoria_editar is defined and categoria_editar %}
                    {% set ids_iniciales = categoria_editar.serie|map(s => s.id)|join(',') %}
                {% endif %}

                <input type="hidden" name="series_ids" id="inputSeriesIds" value="{{ ids_iniciales }}">

                <div class="series-grid">
                    {% for serie in series %}
                        {% set is_selected = false %}

                        {% if categoria_editar is defined and categoria_editar %}
                            {% for serie_cat in categoria_editar.serie %}
                                {% if serie_cat.id == serie.id %}
                                    {% set is_selected = true %}
                                {% endif %}
                            {% endfor %}
                        {% endif %}

                        <div class="serie-card {{ is_selected ? 'selected' : '' }}" onclick="toggleSerie(this, {{ serie.id }})">
                            {% if(serie.posterPath) %}
                                <img src="https://image.tmdb.org/t/p/w500{{ serie.posterPath }}" alt="{{ serie.name }}" class="card-img">
                            {% else %}
                                <img src="{{ asset('/imagenes/no_data.png')}}" alt="no_data" class="no_data">
                            {% endif%}

                            <div class="serie-name-mini">{{ serie.name }}</div>
                        </div>
                    {% endfor %}
                </div>

                <button type="submit" class="btn-submit">
                    {% if categoria_editar is defined and categoria_editar %}
                        EXECUTE_UPDATE_PROTOCOL
                    {% else %}
                        EXECUTE_CREATION_PROTOCOL
                    {% endif %}
                </button>

                {% if categoria_editar is defined and categoria_editar %}
                    <a href="{{ path('app_categoria') }}" class="btn-cancel">[ CANCEL EDITING ]</a>
                {% endif %}
            </form>

        </main>
    </div>

    <script>
        const inputOculto = document.getElementById('inputSeriesIds');
        let rawValue = inputOculto.value;
        let seleccionados = rawValue ? rawValue.split(',').map(Number) : [];

        // Hacemos scroll automático solo si estamos editando
        {% if categoria_editar is defined and categoria_editar %}
        document.getElementById('mainForm').scrollIntoView({ behavior: 'smooth' });
        {% endif %}

        function toggleSerie(elemento, id) {
            elemento.classList.toggle('selected');

            if (seleccionados.includes(id)) {
                seleccionados = seleccionados.filter(item => item !== id);
            } else {
                seleccionados.push(id);
            }
            inputOculto.value = seleccionados.join(',');
        }
    </script>

{% endblock %}
