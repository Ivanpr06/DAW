{% extends 'base.html.twig' %}

{% block title %}REGISTRO | Access Control{% endblock %}

{% block navbar %}{% endblock %}

{% block body %}
    <style>
        body {
            background-color: #050505;
            font-family: 'Roboto Mono', monospace;
            height: 100vh;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .retro-grid {
            position: absolute; width: 200%; height: 100%; bottom: -50%; left: -50%;
            background-image:
                linear-gradient(rgba(0, 255, 255, 0.3) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 255, 255, 0.3) 1px, transparent 1px);
            background-size: 50px 50px;
            transform: perspective(500px) rotateX(60deg);
            animation: moveGrid 5s linear infinite;
            opacity: 0.15; z-index: 0; pointer-events: none;
        }
        @keyframes moveGrid {
            0% { transform: perspective(500px) rotateX(60deg) translateY(0); }
            100% { transform: perspective(500px) rotateX(60deg) translateY(50px); }
        }

        .login-wrapper {
            display: flex; width: 900px; height: 550px;
            background: rgba(15, 15, 15, 0.95);
            border: 1px solid #00ffff;
            box-shadow: 0 0 40px rgba(0, 255, 255, 0.1);
            z-index: 10; position: relative;
        }

        .corner-decor {
            position: absolute; width: 20px; height: 20px;
            border: 2px solid #00ffff; transition: all 0.3s;
        }
        .tl { top: -5px; left: -5px; border-bottom: none; border-right: none; }
        .br { bottom: -5px; right: -5px; border-top: none; border-left: none; }

        .info-side {
            flex: 1; padding: 40px; border-right: 1px solid #333;
            display: flex; flex-direction: column; justify-content: space-between;
            background: linear-gradient(135deg, rgba(0,255,255,0.05) 0%, transparent 100%);
            position: relative; overflow: hidden;
        }

        .system-header span {
            color: #00ffff; letter-spacing: 2px; font-size: 0.8rem; display: block; margin-bottom: 5px;
        }
        .system-header h2 {
            font-family: 'Archivo Black', sans-serif; font-size: 2.5rem; line-height: 1; color: white; margin: 0;
        }

        .visual-data {
            font-size: 0.75rem; color: #888; line-height: 1.6;
        }
        .visual-data p { margin-bottom: 5px; }
        .visual-data strong { color: #00ff00; }

        /* Barra de progreso decorativa */
        .capacity-bar {
            width: 100%; height: 4px; background: #333; margin: 15px 0; position: relative;
        }
        .capacity-fill {
            width: 85%; height: 100%; background: #00ffff;
            box-shadow: 0 0 10px #00ffff;
        }

        .big-text-bottom {
            font-size: 3rem; color: #111; font-family: 'Archivo Black', sans-serif;
            text-transform: uppercase;
        }

        .form-side {
            flex: 1; padding: 40px; display: flex; flex-direction: column; justify-content: center;
        }

        .input-group { margin-bottom: 25px; position: relative; }
        .input-label {
            position: absolute; top: -10px; left: 10px;
            background: #0f0f0f; padding: 0 5px;
            font-size: 0.7rem; color: #00ffff; text-transform: uppercase;
        }
        input {
            width: 100%; background: transparent; border: 1px solid #444;
            padding: 15px; color: white; font-family: inherit; font-size: 1rem; outline: none;
        }
        input:focus { border-color: #00ffff; box-shadow: inset 0 0 10px rgba(0, 255, 255, 0.2); }

        .btn-submit {
            width: 100%; padding: 15px; background: #00ffff; border: none;
            color: black; font-weight: bold; font-size: 1.1rem; cursor: pointer;
            transition: 0.3s;
        }
        .btn-submit:hover { background: white; box-shadow: 0 0 20px #00ffff; }

        .toggle-text { margin-top: 20px; font-size: 0.8rem; text-align: center; color: #888; }
        .toggle-text a { color: #00ffff; cursor: pointer; text-decoration: underline; }

        .noise-bg {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            opacity: 0.05; pointer-events: none;
            background-image: url('data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAIAAAACCAYAAABytg0kAAAAGXRFWHRTb2Z0d2FyZQBBZG9iZSBJbWFnZVJlYWR5ccllPAAAABZJREFUeNpi2r9//38gYGAEESAAEGAAasgJOgzOKCoAAAAASUVORK5CYII=');
        }

        .alert-error {
            background-color: rgba(255, 0, 0, 0.15); /* Fondo rojo transparente */
            border: 1px solid #ff3333;                /* Borde rojo neón */
            color: #ff5555;                           /* Texto rojo claro */
            padding: 15px;
            margin-bottom: 25px;
            font-size: 0.8rem;
            text-transform: uppercase;
            text-align: center;
            box-shadow: 0 0 15px rgba(255, 0, 0, 0.2); /* Brillo rojo */
            animation: glitch 0.3s cubic-bezier(.25, .46, .45, .94) both; /* Tu efecto glitch opcional */
        }
    </style>

    <div class="scanlines"></div>
    <div class="retro-grid"></div>

    <div class="login-wrapper">
        <div class="corner-decor tl"></div>
        <div class="corner-decor br"></div>

        <div class="info-side">
            <div class="noise-bg"></div>

            <div class="system-header">
                <span>NEW_USER_PROTOCOL</span>
                <h2>NUEVO<br>RECLUTA</h2>
            </div>

            <div class="visual-data">
                <p>ESTADO DEL SERVIDOR: <strong style="color:#0f0">ONLINE</strong></p>

                <div class="capacity-bar">
                    <div class="capacity-fill"></div>
                </div>

                <p>> Generando claves criptográficas...</p>
                <p>> Permisos por defecto: Nivel 1 (Lectura)</p>
                <br>
                <p style="opacity: 0.7; font-style: italic;">
                    "La memoria es un archivo corrupto. Únete a la red para preservarla."
                </p>
            </div>

            <div class="big-text-bottom">JOIN_</div>
        </div>

        <div class="form-side">
            {% for mensaje in app.flashes('error') %}
                <div class="alert-error">
                    ⚠️ {{ mensaje }}
                </div>
            {% endfor %}
            <form method="post">
                <h3 style="margin-bottom: 30px; font-family: 'Archivo Black', sans-serif; color: white;">CREAR ID</h3>

                <div class="input-group">
                    <span class="input-label">Alias (Username)</span>
                    <input type="text" name="nombre" required placeholder="Ej. Dexter">
                </div>

                <div class="input-group">
                    <span class="input-label">Email Oficial</span>
                    <input type="email" name="correo" required placeholder="user@cartoonlost.net">
                </div>

                <div class="input-group">
                    <span class="input-label">Crear Clave</span>
                    <input type="password" name="contrasena" required placeholder="••••••••••">
                </div>

                <button type="submit" class="btn-submit">GENERAR PERFIL</button>

                <div class="toggle-text">
                    ¿Ya tienes ID? <a href="{{ path('app_login') }}">Iniciar Sesión</a>
                    <br><br>
                    <a href="{{ path('app_home') }}" style="color: #666; text-decoration: none; font-size: 0.7rem;">[X] CANCELAR Y SALIR</a>
                </div>
            </form>

        </div>
    </div>
{% endblock %}
