{% extends 'base.html.twig' %}

{% block title %} DATA_LOAD | CARTOON LOST{% endblock %}

{% block navbar %}{% endblock %}

{% block body %}
    <style>
        .admin-container {
            display: grid;
            grid-template-columns: 260px 1fr;
            min-height: 100vh;
            font-family: 'Roboto Mono', monospace;
            background-color: #020202;
            color: #ccc;
        }

        .admin-content {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            background: radial-gradient(circle at center, #111 0%, #020202 100%);
        }

        .msg-box {
            text-align: center;
            border: 1px solid #333;
            padding: 40px 60px;
            background: rgba(0, 0, 0, 0.8);
            box-shadow: 0 0 30px rgba(0, 255, 255, 0.1);
            position: relative;
            max-width: 500px;
            z-index: 1;
        }

        .icon-check {
            font-size: 3rem;
            color: var(--accent, #00ffff);
            margin-bottom: 20px;
            display: inline-block;
            animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        h1 {
            color: white;
            font-family: 'Archivo Black', sans-serif;
            font-size: 1.5rem;
            margin: 0 0 10px 0;
            letter-spacing: -1px;
        }

        p { color: #888; font-size: 0.9rem; margin-bottom: 30px; }

        .btn-back {
            display: inline-block;
            border: 1px solid var(--accent, #00ffff);
            color: var(--accent, #00ffff);
            padding: 10px 25px;
            text-decoration: none;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s;
            position: relative;
            z-index: 10;
            cursor: pointer;
        }

        .btn-back:hover {
            background: var(--accent, #00ffff);
            color: black;
            box-shadow: 0 0 15px var(--accent, #00ffff);
        }

        @keyframes popIn {
            0% { transform: scale(0); opacity: 0; }
            80% { transform: scale(1.2); opacity: 1; }
            100% { transform: scale(1); }
        }
    </style>

    <div class="admin-container">
        {% include 'admin/adminNavbar.html.twig' %}

        <main class="admin-content">

            <div class="msg-box">
                <div class="icon-check">✔</div>
                <h1>DATABASE UPDATED</h1>
                <p>La carga de datos se ha completado correctamente.<br>El sistema está sincronizado.</p>

                <a href="{{ path('app_home') }}" class="btn-back">
                    [ VOLVER AL HOME ]
                </a>
            </div>

        </main>
    </div>
{% endblock %}
