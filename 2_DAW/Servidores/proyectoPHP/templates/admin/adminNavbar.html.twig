{% set current_route = app.request.attributes.get('_route') %}
<style>
    .admin-sidebar {
        background: #080808;
        border-right: 1px solid #333;
        padding: 20px;
        display: flex;
        flex-direction: column;
    }

    .sidebar-header {
        font-family: 'Archivo Black', sans-serif;
        color: var(--accent, #00ffff);
        font-size: 1.2rem;
        margin-bottom: 40px;
        border-bottom: 2px solid #333;
        padding-bottom: 10px;
    }
    .sidebar-header span { font-size: 0.7rem; color: #666; margin-left: 5px; }

    .nav-label { font-size: 0.7rem; color: #555; margin-bottom: 10px; font-weight: bold; }

    .admin-link {
        display: block;
        color: #888;
        text-decoration: none;
        padding: 10px 0;
        transition: all 0.2s;
        border-left: 2px solid transparent;
        padding-left: 10px;
    }

    .admin-link:hover, .admin-link.active {
        color: var(--accent, #00ffff);
        background: rgba(0, 255, 255, 0.05);
        border-left-color: var(--accent, #00ffff);
        text-shadow: 0 0 5px rgba(0, 255, 255, 0.3);
    }

    .back-link:hover { color: #ff5555; border-left-color: #ff5555; background: rgba(255, 85, 85, 0.05); }

    .system-status {
        margin-top: auto;
        font-size: 0.7rem;
        color: #444;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .status-light { width: 8px; height: 8px; background: #00ff00; border-radius: 50%; box-shadow: 0 0 5px #00ff00; }
    .blink { animation: blinker 2s linear infinite; }
    @keyframes blinker { 50% { opacity: 0; } }
</style>

<aside class="admin-sidebar">
    <div class="sidebar-header">
        CORE_SYSTEM<span>v.2.0</span>
    </div>

    <nav class="admin-nav">
        <div class="nav-label">>> DIRECTORIES</div>
        <a href="{{ path('app_admin') }}" class="admin-link {{ current_route == 'app_admin' ? 'active' : '' }}">[ STATS ]</a>
        <a href="{{ path('app_categoria') }}" class="admin-link {{ current_route == 'app_categoria' ? 'active' : '' }}">[ CATEGORIES ]</a>
        <a href="{{ path('app_cargarDatos') }}" class="admin-link {{ current_route == 'app_cargarDatos' ? 'active' : '' }}">[ DATA_LOAD ]</a>

        <div class="nav-label" style="margin-top: 20px;">>> COMMANDS</div>
        <a href="{{ path('app_home') }}" class="admin-link back-link">< EXIT_TO_FRONTEND</a>
        <a href="{{ path('app_logout') }}" class="admin-link back-link">< LOGOUT</a>
    </nav>

    <div class="system-status">
        <div class="status-light blink"></div>
        SERVER: ONLINE
    </div>
</aside>
